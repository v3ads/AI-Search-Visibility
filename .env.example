# PostgreSQL connection string (provided by Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret for express-session (generate a strong random string)
SESSION_SECRET=your-strong-random-secret-here

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Public URL of the deployed app (used in OpenRouter HTTP-Referer header)
APP_URL=https://your-app.up.railway.app
